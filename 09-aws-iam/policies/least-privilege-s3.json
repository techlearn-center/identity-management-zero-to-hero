{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "AllowListBucket",
      "Effect": "Allow",
      "Action": ["s3:ListBucket"],
      "Resource": "arn:aws:s3:::identity-lab-data",
      "Condition": {
        "StringLike": {"s3:prefix": ["uploads/*", "exports/*"]}
      }
    },
    {
      "Sid": "AllowReadWriteObjects",
      "Effect": "Allow",
      "Action": ["s3:GetObject", "s3:PutObject"],
      "Resource": "arn:aws:s3:::identity-lab-data/uploads/*"
    },
    {
      "Sid": "DenyDeleteObjects",
      "Effect": "Deny",
      "Action": ["s3:DeleteObject", "s3:DeleteBucket"],
      "Resource": "arn:aws:s3:::identity-lab-data/*"
    }
  ]
}
