# ─── Auth0 Configuration ─────────────────────────────────────
# Your Auth0 tenant domain (without https://)
AUTH0_DOMAIN=your-tenant.auth0.com

# The API identifier configured in Auth0 Dashboard → APIs
AUTH0_AUDIENCE=https://api.example.com

# ─── Server Configuration ────────────────────────────────────
HOST=0.0.0.0
PORT=3001

# ─── CORS Configuration ─────────────────────────────────────
# Comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ─── Logging ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL

# ─── Auth0 M2M Credentials (for requesting M2M tokens) ──────
# Only needed if this service calls other Auth0-protected APIs
M2M_CLIENT_ID=your_m2m_client_id
M2M_CLIENT_SECRET=your_m2m_client_secret
M2M_TARGET_AUDIENCE=https://target-api.example.com
